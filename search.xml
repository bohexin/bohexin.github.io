<figure class="highlight plain"><table><tr><td class="code"><pre><span class="line">&lt;html lang&#x3D;&quot;en&quot;&gt;</span><br><span class="line"></span><br><span class="line">&lt;head&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line">    &lt;meta charset&#x3D;&quot;UTF-8&quot;&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">    &lt;meta name&#x3D;&quot;viewport&quot; content&#x3D;&quot;width&#x3D;device-width, initial-scale&#x3D;1.0&quot;&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">    &lt;meta http-equiv&#x3D;&quot;X-UA-Compatible&quot; content&#x3D;&quot;ie&#x3D;edge&quot;&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">  &lt;title&gt;Document&lt;&#x2F;title&gt;</span><br><span class="line"></span><br><span class="line">  &lt;link rel&#x3D;&quot;stylesheet&quot; href&#x3D;&quot;css&#x2F;main.css&quot; type&#x3D;&quot;text&#x2F;css&quot;&gt;</span><br><span class="line"></span><br><span class="line">    &lt;script src&#x3D;&quot;js&#x2F;form.js&quot; type&#x3D;&quot;text&#x2F;javascript&quot;&gt;&lt;&#x2F;script&gt;</span><br><span class="line"></span><br><span class="line">&lt;&#x2F;head&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">&lt;body&gt;</span><br><span class="line"></span><br><span class="line">    &lt;div id&#x3D;&quot;divcontent&quot; align&#x3D;&quot;center&quot;&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">   &lt;form action&#x3D;&quot;registersuccess.html&quot; method&#x3D;&quot;POST&quot; onsubmit&#x3D;&quot;return checkForm();&quot;&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">        &lt;table width&#x3D;&quot;850px&quot; border&#x3D;&quot;0&quot; cellspacing&#x3D;&quot;0&quot;&gt;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">​      &lt;tr&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;td style&#x3D;&quot;padding: 5px;&quot;&gt;&lt;h1&gt;新会员注册&lt;&#x2F;h1&gt;</span><br><span class="line"></span><br><span class="line">                &lt;table width&#x3D;&quot;70%&quot; border&#x3D;&quot;0&quot; cellsapcing&#x3D;&quot;2&quot; class&#x3D;&quot;upline&quot;&gt;&lt;&#x2F;table&gt;</span><br><span class="line"></span><br><span class="line">​      &lt;tr&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;td style&#x3D;&quot;text-align:right;width: 20%;&quot;&gt;会员邮箱&lt;&#x2F;td&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;td style&#x3D;&quot;width: 40%;&quot;&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;input type&#x3D;&quot;text&quot; class&#x3D;&quot;textinput&quot; id&#x3D;&quot;emali&quot; name&#x3D;&quot;email&quot; onkeyup&#x3D;&quot;checkEmail();&quot;&#x2F;&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;&#x2F;td&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;td colspan&#x3D;&quot;2&quot;&gt;&lt;span id&#x3D;&quot;emailMsg&quot;&gt;&lt;&#x2F;span&gt;</span><br><span class="line"></span><br><span class="line">​          &lt;font color&#x3D;&quot;#999999&quot;&gt;输入有效邮箱地址&lt;&#x2F;font&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;&#x2F;td&gt;</span><br><span class="line"></span><br><span class="line">​      &lt;&#x2F;tr&gt;</span><br><span class="line"></span><br><span class="line">​      &lt;tr&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;td style&#x3D;&quot;text-align: right;&quot;&gt;会员名&lt;&#x2F;td&gt;</span><br><span class="line"></span><br><span class="line">​        &lt;td&gt;</span><br><span class="line"></span><br><span class="line">​        