<figure class="highlight plain"><table><tr><td class="code"><pre><span class="line">var emailObj;</span><br><span class="line"></span><br><span class="line">var usernameObj;</span><br><span class="line"></span><br><span class="line">var passwordObj;</span><br><span class="line"></span><br><span class="line">var confirmObj;</span><br><span class="line"></span><br><span class="line">var emailMsg;</span><br><span class="line"></span><br><span class="line">var usernameMsg;</span><br><span class="line"></span><br><span class="line">var passwordMsg;</span><br><span class="line"></span><br><span class="line">var confirmMsg;</span><br><span class="line"></span><br><span class="line">&#x2F;&#x2F; 页面加载后 获取页面对象</span><br><span class="line"></span><br><span class="line">window.onload &#x3D; function()&#123;</span><br><span class="line"></span><br><span class="line">  emailObj &#x3D; document.getElementById(&quot;email&quot;);</span><br><span class="line"></span><br><span class="line">  usernameObj &#x3D; document.getElementById(&quot;username&quot;);</span><br><span class="line"></span><br><span class="line">  passwordObj &#x3D; document.getElementById(&quot;password&quot;);</span><br><span class="line"></span><br><span class="line">  confirmObj &#x3D; document.getElementById(&quot;confirm&quot;);</span><br><span class="line"></span><br><span class="line">  emailMsg &#x3D; document.getElementById(&quot;emailMsg&quot;);</span><br><span class="line"></span><br><span class="line">  usernameMsg &#x3D; document.getElementById(&quot;usernameMsg&quot;);</span><br><span class="line"></span><br><span class="line">  passwordMsg &#x3D; document.getElementById(&quot;passwordMsg&quot;);</span><br><span class="line"></span><br><span class="line">  confirmMsg &#x3D; document.getElementById(&quot;confirmMsg&quot;);</span><br><span class="line"></span><br><span class="line">&#125;;</span><br><span class="line"></span><br><span class="line">&#x2F;&#x2F; 验证整个表单</span><br><span class="line"></span><br><span class="line">function checkForm()&#123;</span><br><span class="line"></span><br><span class="line">  var bEmail &#x3D; checkEmali();</span><br><span class="line"></span><br><span class="line">  var bUsername &#x3D; checkUsername();</span><br><span class="line"></span><br><span class="line">  var bPassword &#x3D; checkPassword();</span><br><span class="line"></span><br><span class="line">  var bConfirm &#x3D; checkConfirm();</span><br><span class="line"></span><br><span class="line">  &#x2F;&#x2F;return false后 事件被取消</span><br><span class="line"></span><br><span class="line">  return bUsername &amp;&amp; bEmail &amp;&amp; bPassword &amp;&amp; bConfirm ;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#x2F;&#x2F; 验证邮箱       </span><br><span class="line"></span><br><span class="line">function checkEmali()&#123;</span><br><span class="line"></span><br><span class="line">  var regex &#x3D; &#x2F;^[\w-]+@([\w-]+\.)+[a-zA-Z]&#123;2,4&#125;$&#x2F;;</span><br><span class="line"></span><br><span class="line">  var value &#x3D; emailObj.value;</span><br><span class="line"></span><br><span class="line">  var msg &#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">  if(!value)</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;邮箱必须填写&quot;;</span><br><span class="line"></span><br><span class="line">  else if(!regex.text(value))</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;邮箱格式不合法:&quot;;</span><br><span class="line"></span><br><span class="line">  emailMsg.innerHTML &#x3D; msg;</span><br><span class="line"></span><br><span class="line">  emailObj.parentNode.parentNode.style.color &#x3D; msg &#x3D; &quot;&quot; ? &quot;black&quot; : &quot;red&quot;;</span><br><span class="line"></span><br><span class="line">  return msg &#x3D;&#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#x2F;&#x2F; 验证用户名</span><br><span class="line"></span><br><span class="line">function checkUsername()&#123;</span><br><span class="line"></span><br><span class="line">  var regex &#x3D; &#x2F;^[a-zA-z_]\w&#123;0,9&#125;$&#x2F;; &#x2F;&#x2F;字母数字下划线 1-10位，不能是数字开头</span><br><span class="line"></span><br><span class="line">  var value &#x3D; usernameObj.value;</span><br><span class="line"></span><br><span class="line">  var msg &#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">  &#x2F;&#x2F;如果用户为null或者&quot;&quot;,!value值为false，如果不为空则为true</span><br><span class="line"></span><br><span class="line">  if(!value)</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;用户必须填写:&quot;;</span><br><span class="line"></span><br><span class="line">  else if (!regex.text(value))</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;用户名不合法&quot;;</span><br><span class="line"></span><br><span class="line">  usernameMsg.innerHTML &#x3D; msg;</span><br><span class="line"></span><br><span class="line">  usernameObj.parentNode.parentNode.style.color &#x3D; msg &#x3D;&#x3D; &quot;&quot; ? &quot;black&quot; :&quot;red&quot;;</span><br><span class="line"></span><br><span class="line">  return msg &#x3D;&#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#x2F;&#x2F; 验证密码</span><br><span class="line"></span><br><span class="line">function checkPassword()&#123;</span><br><span class="line"></span><br><span class="line">  var regex &#x3D; &#x2F;^.&#123;6,16&#125;$&#x2F;; &#x2F;&#x2F;字母数字下划线 1-10位，不能是数字开头</span><br><span class="line"></span><br><span class="line">  var value &#x3D; passwordObj.value;</span><br><span class="line"></span><br><span class="line">  var msg &#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">  &#x2F;&#x2F;如果用户为null或者&quot;&quot;,!value值为false，如果不为空则为true</span><br><span class="line"></span><br><span class="line">  if(!value)</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;密码必须填写:&quot;;</span><br><span class="line"></span><br><span class="line">  else if (!regex.text(value))</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;密码不合法&quot;;</span><br><span class="line"></span><br><span class="line">  passwordMsg.innerHTML &#x3D; msg;</span><br><span class="line"></span><br><span class="line">  passwordObj.parentNode.parentNode.style.color &#x3D; msg &#x3D;&#x3D; &quot;&quot; ? &quot;black&quot; :&quot;red&quot;;</span><br><span class="line"></span><br><span class="line">  return msg &#x3D;&#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#x2F;&#x2F;验证确认密码</span><br><span class="line"></span><br><span class="line">&#x2F;&#x2F; 验证用户名</span><br><span class="line"></span><br><span class="line">function checkConfirm()&#123;</span><br><span class="line"></span><br><span class="line">  var passwordValue &#x3D; passwordObj.value;</span><br><span class="line"></span><br><span class="line">  var confirmValue &#x3D; confirmObj.value; </span><br><span class="line"></span><br><span class="line">  var msg &#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">  &#x2F;&#x2F;如果用户为null或者&quot;&quot;,!value值为false，如果不为空则为true</span><br><span class="line"></span><br><span class="line">  if(!confirmValue)</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;确认密码必须填写:&quot;;</span><br><span class="line"></span><br><span class="line">  else if (passwordValue !&#x3D; confirmValue)</span><br><span class="line"></span><br><span class="line">  msg &#x3D; &quot;密码不一致&quot;;</span><br><span class="line"></span><br><span class="line">  confirmMsg.innerHTML &#x3D; msg;</span><br><span class="line"></span><br><span class="line">  confirmObj.parentNode.parentNode.style.color &#x3D; msg &#x3D;&#x3D; &quot;&quot; ? &quot;black&quot; :&quot;red&quot;;</span><br><span class="line"></span><br><span class="line">  return msg &#x3D;&#x3D; &quot;&quot;;</span><br><span class="line"></span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>

